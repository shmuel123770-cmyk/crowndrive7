{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "users": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid && !data.exists() && root.child('admins').child(auth.uid).val() !== true",
        ".validate": "newData.hasChildren(['name','email','role']) && newData.child('role').val().matches(/^(renter|owner)$/) && newData.child('email').val() === auth.token.email && !newData.hasChild('blocked')",
        "photoURL": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isString() && newData.val().length <= 1400000 && (newData.val().matches(/^data:image/) || newData.val().matches(/^https:/))"
        },
        "role": {
          ".write": "auth != null && auth.uid === $uid && !data.exists()",
          ".validate": "newData.val() === 'renter' || newData.val() === 'owner'"
        },
        "name": {
          ".write": "auth != null && auth.uid === $uid && root.child('verificationStatus').child($uid).val() !== 'pending' && root.child('verificationStatus').child($uid).val() !== 'approved'",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "phone": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "birthDate": {
          ".write": "auth != null && auth.uid === $uid && root.child('verificationStatus').child($uid).val() !== 'pending' && root.child('verificationStatus').child($uid).val() !== 'approved'",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "legalAcceptance": {
          ".validate": "newData.hasChildren(['termsVersion','privacyVersion','acceptedAt']) && newData.child('termsVersion').isString() && newData.child('termsVersion').val().length <= 60 && newData.child('privacyVersion').isString() && newData.child('privacyVersion').val().length <= 60 && newData.child('acceptedAt').isNumber()"
        },
        "verification": {
          "email": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean() && newData.val() === (auth.token.email_verified === true)"
          }
        }
      }
    },
    "verificationStatus": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "cars": {
      ".read": true,
      ".indexOn": ["ownerUid", "status"],
      "$carId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.hasChildren(['make','model','ownerUid']) && newData.child('make').isString() && newData.child('make').val().length <= 80 && newData.child('model').val().length <= 80 && (!data.exists() || newData.child('ownerUid').val() === data.child('ownerUid').val()) && (!data.exists() || root.child('admins').child(auth.uid).val() === true || newData.child('featured').val() === data.child('featured').val()) && (!data.exists() || newData.child('createdAt').val() === data.child('createdAt').val())",
        "photoUrl": {
          ".validate": "newData.isString() && newData.val().length <= 1000000 && (newData.val().length === 0 || newData.val().matches(/^data:image/) || newData.val().matches(/^https:/))"
        },
        "photos": {
          "$i": {
            ".validate": "newData.isString() && newData.val().length <= 1000000 && (newData.val().matches(/^data:image/) || newData.val().matches(/^https:/))"
          }
        }
      }
    },
    "bookings": {
      ".indexOn": ["ownerUid", "renterUid", "carId"],
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || (query.orderByChild === 'ownerUid' && query.equalTo === auth.uid) || (query.orderByChild === 'renterUid' && query.equalTo === auth.uid))",
      "$id": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('ownerUid').val() === auth.uid || data.child('renterUid').val() === auth.uid)"
      }
    },
    "inquiries": {
      ".indexOn": ["ownerUid", "renterUid", "carId"],
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || (query.orderByChild === 'ownerUid' && query.equalTo === auth.uid) || (query.orderByChild === 'renterUid' && query.equalTo === auth.uid))",
      "$id": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('ownerUid').val() === auth.uid || data.child('renterUid').val() === auth.uid)"
      }
    },
    "messages": {
      "admin": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".write": false,
          "$msgId": {
            ".validate": "newData.hasChildren(['senderUid','createdAt']) && newData.child('senderUid').val() === auth.uid && newData.child('createdAt').isNumber() && (!newData.hasChild('text') || (newData.child('text').isString() && newData.child('text').val().length <= 2000)) && (!newData.child('fromAdmin').exists() || newData.child('fromAdmin').val() === (root.child('admins').child(auth.uid).val() === true)) && (!newData.child('attachment').exists() || newData.child('attachment/path').val().length <= 1400000)"
          }
        }
      },
      "inquiry": {
        "$inquiryId": {
          ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('inquiries').child($inquiryId).child('ownerUid').val() === auth.uid || root.child('inquiries').child($inquiryId).child('renterUid').val() === auth.uid)"
        }
      },
      "$bookingId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('bookings').child($bookingId).child('ownerUid').val() === auth.uid || root.child('bookings').child($bookingId).child('renterUid').val() === auth.uid)"
      }
    },
    "supportGuestState": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        "firstSent": {
          ".write": false,
          ".validate": "newData.isBoolean()"
        },
        "adminReplied": {
          ".write": false,
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "payments": {
      ".indexOn": ["ownerUid", "renterUid"],
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || (query.orderByChild === 'ownerUid' && query.equalTo === auth.uid) || (query.orderByChild === 'renterUid' && query.equalTo === auth.uid))",
      "$bookingId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('ownerUid').val() === auth.uid || data.child('renterUid').val() === auth.uid)"
      }
    },
    "privateUserDocuments": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      }
    },
    "privateCarDetails": {
      "$carId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('ownerUid').val() === auth.uid)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "!newData.exists() || newData.child('ownerUid').val() === auth.uid || root.child('admins').child(auth.uid).val() === true"
      }
    },
    "ratings": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": ["carId", "targetUid", "bookingId"]
    },
    "publicRatings": {
      ".read": true,
      ".indexOn": ["carId", "targetUid"]
    },
    "auditLogs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "adminNotifications": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "config": {
      ".read": true,
      "maintenance": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.hasChild('on')"
      }
    },
    "migration": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "crowndrive-live": {
      "state": {
        "data": {
          ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
        }
      }
    }
  }
}
